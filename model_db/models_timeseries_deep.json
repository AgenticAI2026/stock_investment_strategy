      "forbidden": ["random_split", "global_shuffle"]
    },

    "interpretability": {
      "level": "low",
      "explainable_methods": ["attention_rollout_if_available", "feature_ablation"]
    },

    "operational": {
      "training_speed": "slow",
      "inference_latency": "medium",
      "gpu_required": true
    }
  },

