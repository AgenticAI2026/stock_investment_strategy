      "seasonality_strength_min": 0.15,
      "missing_rate_max": 0.0,
      "horizon_steps_range": [1, 120]
    },

    "exclusion_rules": [
      { "if": { "gpu_available": false }, "then": "exclude_or_deprioritize" },
